{
  "name": "mcp-server-macos-use",
  "version": "0.1.17",
  "description": "MCP server that lets AI agents control any macOS application through accessibility APIs",
  "bin": {
    "mcp-server-macos-use": "bin/mcp-server-macos-use"
  },
  "scripts": {
    "postinstall": "xcrun swift build -c release",
    "build": "xcrun swift build -c release",
    "web:dev": "next dev",
    "web:build": "next build",
    "web:start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "macos",
    "accessibility",
    "ai",
    "claude",
    "automation",
    "model-context-protocol"
  ],
  "author": "Mediar <matt@mediar.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mediar-ai/mcp-server-macos-use.git"
  },
  "homepage": "https://macos-use.dev",
  "bugs": {
    "url": "https://github.com/mediar-ai/mcp-server-macos-use/issues"
  },
  "os": [
    "darwin"
  ],
  "engines": {
    "node": ">=16"
  },
  "dependencies": {
    "@m13v/seo-components": "^0.16.0",
    "@remotion/player": "^4.0.434",
    "@seo/components": "npm:@m13v/seo-components@^0.16.0",
    "framer-motion": "^11.15.0",
    "lottie-react": "^2.4.1",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.434"
  },
  "devDependencies": {
    "@assistant-ui/react": "^0.12.25",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.103.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.0"
  }
}
